{
  "name": "proofkind",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
