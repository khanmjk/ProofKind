    "seed:profile": "tsx scripts/seed-public-profile.ts"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "lucide-react": "^1.20.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
